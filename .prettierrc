{
    "bracketSpacing": true,
    "endOfLine": "lf",
    "overrides": [
        {
            "files": ["*.html"],
            "options": {
                "bracketSameLine": true,
                "htmlWhitespaceSensitivity": "css",
                "printWidth": 120,
                "singleAttributePerLine": false
            }
        }
    ],
    "printWidth": 80,
    "semi": true,
    "singleQuote": false,
    "tabWidth": 4,
    "trailingComma": "es5",
    "useTabs": false
}
